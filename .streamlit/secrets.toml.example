ANTHROPIC_API_KEY = ""
# Google ログイン済みメールのうち、ここに列挙したものだけ利用可（=課金できる人）。
APP_ALLOWED_USERS = []   # 例: ["taro@example.com", "hanako@example.com"]
# 以下は P3 で使用（P1 では未使用）
SP_API_LWA_APP_ID = ""
SP_API_LWA_CLIENT_SECRET = ""
SP_API_REFRESH_TOKEN = ""
DROPBOX_APP_KEY = ""
DROPBOX_APP_SECRET = ""
DROPBOX_REFRESH_TOKEN = ""

# Google OIDC ログイン（st.login）。top-level キーより後に置くこと（TOML 仕様）。
# redirect_uri はローカル=http://localhost:8501/oauth2callback、
# デプロイ後=https://<アプリURL>/oauth2callback に合わせる。
# cookie_secret は強いランダム文字列。client_id/secret は Google Cloud Console で発行。
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = ""
client_id = ""
client_secret = ""
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
